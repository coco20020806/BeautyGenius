{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "video",
    "generated_at",
    "model",
    "asr_model",
    "steps",
    "contract_version",
    "taxonomy_version",
    "makeup_replication_refs"
  ],
  "properties": {
    "contract_version": { "const": "v2.1" },
    "taxonomy_version": { "type": "string" },
    "skipped_primaries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "makeup_replication_refs": {
      "type": "object",
      "required": ["refs_version", "after", "before", "pair_validation"],
      "properties": {
        "refs_version": { "const": "1" },
        "after": { "$ref": "#/$defs/replication_frame" },
        "before": { "$ref": "#/$defs/replication_frame" },
        "pair_validation": {
          "type": "object",
          "required": [
            "same_person",
            "before_is_bareer",
            "after_is_full_makeup",
            "pass",
            "reason"
          ],
          "properties": {
            "same_person": { "type": "boolean" },
            "before_is_bareer": { "type": "boolean" },
            "after_is_full_makeup": { "type": "boolean" },
            "pass": { "type": "boolean" },
            "reason": { "type": "string" }
          }
        }
      }
    },
    "video": {
      "type": "object",
      "required": ["source_path", "duration_sec"],
      "properties": {
        "source_path": { "type": "string" },
        "duration_sec": { "type": "number" },
        "fps": { "type": "number" },
        "analysis_path": { "type": "string" },
        "upload_compressed": { "type": "boolean" }
      }
    },
    "generated_at": { "type": "string" },
    "model": { "type": "string" },
    "asr_model": { "type": "string" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_index", "step_name", "taxonomy", "time_range", "text", "keyframes"],
        "properties": {
          "step_index": { "type": "integer", "minimum": 1 },
          "step_name": { "type": "string" },
          "taxonomy": {
            "type": "object",
            "required": ["primary", "sub_steps", "skipped"],
            "properties": {
              "primary": { "type": "string" },
              "sub_steps": {
                "type": "array",
                "items": { "type": "string" }
              },
              "skipped": { "type": "boolean" }
            }
          },
          "time_range": {
            "type": "object",
            "required": ["start_sec", "end_sec", "start_label", "end_label"],
            "properties": {
              "start_sec": { "type": "number" },
              "end_sec": { "type": "number" },
              "start_label": { "type": "string" },
              "end_label": { "type": "string" }
            }
          },
          "text": {
            "type": "object",
            "required": ["subtitles", "on_screen", "voiceover"],
            "properties": {
              "subtitles": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time_sec": { "type": "number" },
                    "text": { "type": "string" }
                  }
                }
              },
              "on_screen": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "time_sec": { "type": "number" },
                    "text": { "type": "string" }
                  }
                }
              },
              "voiceover": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["start_sec", "end_sec", "text"],
                  "properties": {
                    "start_sec": { "type": "number" },
                    "end_sec": { "type": "number" },
                    "text": { "type": "string" }
                  }
                }
              }
            }
          },
          "keyframes": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["index_in_step", "role", "timestamp_sec", "filename"],
              "properties": {
                "index_in_step": { "type": "integer", "minimum": 1 },
                "role": {
                  "type": "string",
                  "enum": ["step_start_face", "step_end_face", "makeup_detail"]
                },
                "timestamp_sec": { "type": "number" },
                "label": { "type": "string" },
                "filename": { "type": "string" },
                "validation": {
                  "type": "object",
                  "properties": {
                    "pass": { "type": "boolean" },
                    "has_face": {},
                    "face_sufficient": {},
                    "region_match": {},
                    "reason": { "type": "string" },
                    "l1_pass": { "type": "boolean" },
                    "l2_skipped": { "type": "boolean" },
                    "skipped": { "type": "boolean" }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "replication_frame": {
      "type": "object",
      "required": ["role", "timestamp_sec", "label", "filename", "source", "validation"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["replication_before", "replication_after"]
        },
        "timestamp_sec": { "type": "number" },
        "label": { "type": "string" },
        "filename": { "type": "string" },
        "source": { "type": "string" },
        "validation": {
          "type": "object",
          "properties": {
            "pass": { "type": "boolean" },
            "l1_pass": { "type": "boolean" },
            "has_face": {},
            "face_sufficient": {},
            "makeup_complete": {},
            "makeup_minimal": {},
            "reason": { "type": "string" },
            "l2_skipped": { "type": "boolean" }
          }
        }
      }
    }
  }
}
